    "ios": "npm run build && cap sync ios && cap open ios"
  },
  "dependencies": {
    "@capacitor/android": "^6.0.0",
    "@capacitor/browser": "^6.0.6",
    "@capacitor/camera": "^6.0.0",
    "@capacitor/core": "^6.0.0",
    "@capacitor/ios": "^6.0.0",
    "@capacitor/status-bar": "^6.0.0",
    "@headlessui/vue": "^1.7.22",
    "@tabler/icons": "^3.14.0",
    "@tabler/icons-vue": "^3.12.0",
    "bootstrap": "^5.3.3",
    "peerjs": "^1.5.5",
    "sass": "^1.77.6",
    "swiper": "^11.1.10",
    "vue": "^3.4.37",
    "vue-i18n": "^9.14.5",
    "vue-router": "^4.4.3",
    "ws": "^8.19.0"
  },
  "devDependencies": {
    "@capacitor/cli": "^6.0.0",
    "@types/node": "^22.5.1",
    "@vitejs/plugin-vue": "^5.1.2",

{
  "name": "ebetstream-mobile",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc -b && vite build",
    "preview": "vite preview",
    "cap:init": "cap add android && cap add ios",
    "cap:sync": "npm run build && cap sync",
    "cap:open:android": "cap open android",
